# ─────────────────────────────────────────────────────────────────────────────
# HighFive — vision module .env.example
#
# the vision package is mostly pure python with no required env vars today.
# placeholders here are for future use: model paths, gpu toggles, etc.
# ─────────────────────────────────────────────────────────────────────────────


# === optional / future =======================================================

# absolute path to a custom mediapipe HandLandmarker .task model. if unset
# the package uses the bundled default in vision/core/.
# MEDIAPIPE_MODEL_PATH=

# enable gpu inference (cuda / metal). 0 = cpu only (default), 1 = use gpu.
# VISION_USE_GPU=0

# log level for vision — DEBUG / INFO / WARNING / ERROR.
# VISION_LOG_LEVEL=INFO
